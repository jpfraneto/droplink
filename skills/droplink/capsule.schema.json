{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://droplink.app/schemas/drop-capsule.schema.json",
  "title": "DropLink Drop Capsule",
  "type": "object",
  "required": ["protocol", "version", "source", "project", "drop", "commerce", "approval"],
  "properties": {
    "protocol": { "const": "droplink.drop_capsule" },
    "version": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["url", "agent", "manual"] },
        "url": { "type": "string", "format": "uri" },
        "domain": { "type": "string" },
        "title": { "type": "string" }
      },
      "additionalProperties": false
    },
    "project": {
      "type": "object",
      "required": ["name", "one_liner", "brand_summary", "audience", "voice", "forbidden_vibes"],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "one_liner": { "type": "string", "minLength": 8 },
        "brand_summary": { "type": "string", "minLength": 16 },
        "audience": { "type": "string", "minLength": 3 },
        "voice": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string" } },
        "forbidden_vibes": { "type": "array", "maxItems": 12, "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "drop": {
      "type": "object",
      "required": ["collection_name", "collection_tagline", "visual_direction", "products"],
      "properties": {
        "collection_name": { "type": "string", "minLength": 2 },
        "collection_tagline": { "type": "string", "minLength": 4 },
        "visual_direction": { "type": "string", "minLength": 8 },
        "products": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": [
              "name",
              "type",
              "description",
              "why_this_product",
              "price_cents",
              "currency",
              "image_prompt"
            ],
            "properties": {
              "name": { "type": "string", "minLength": 2 },
              "type": { "type": "string", "minLength": 2 },
              "description": { "type": "string", "minLength": 8 },
              "why_this_product": { "type": "string", "minLength": 8 },
              "price_cents": { "type": "integer", "minimum": 100 },
              "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
              "image_prompt": { "type": "string", "minLength": 8 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "commerce": {
      "type": "object",
      "required": ["platform_fee_bps", "requires_claim_for_live_sales"],
      "properties": {
        "platform_fee_bps": { "type": "integer", "const": 800 },
        "requires_claim_for_live_sales": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "required": ["status", "approved_by"],
      "properties": {
        "status": { "enum": ["preview", "claimed", "live"] },
        "approved_by": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
