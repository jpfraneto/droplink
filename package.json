{
  "name": "droplink",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "bun src/worker.ts",
    "railway:start": "if [ \"$DROPLINK_PROCESS\" = \"worker\" ]; then bun run worker; else bun start; fi",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test": "bun test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "bullmq": "^5.79.1",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "next": "^14.2.35",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "stripe": "^17.5.0",
    "tldts": "^7.4.4",
    "viem": "^2.53.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  }
}
