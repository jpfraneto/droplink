# Minimal local development
# Copy to .env.local, set this one key, then run: bun dev
OPENAI_API_KEY=

# Local app defaults
DROPLINK_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Admin generation gate
# Leave disabled locally for a frictionless admin at /admin.
DROPLINK_REQUIRE_GENERATION_KEY=false
DROPLINK_API_KEY=dev_local_key

# Local persistence and queue
# Empty DATABASE_URL uses data/store.json.
# Empty REDIS_URL makes /admin generation run inline in bun dev.
DATABASE_URL=
DROPLINK_DATA_FILE=
REDIS_URL=

# AI
# If OPENAI_API_KEY is set and these are blank, the app defaults to OpenAI.
AI_PROVIDER=
IMAGE_PROVIDER=
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# Remote Hermes local-Qwen chat route
# Set HERMES_MODE=agent to send study/plan/critique tasks through Hermes.
HERMES_MODE=agent
HERMES_BRIDGE_URL=https://mirror.anky.app
HERMES_BRIDGE_PATH=/api/prompt
HERMES_BRIDGE_MODE=chat
HERMES_BRIDGE_MAX_TOKENS=3500
HERMES_BRIDGE_TIMEOUT_MS=900000
HERMES_BRIDGE_USE_TASKS=false
HERMES_TASKS_PATH=/v1/tasks
HERMES_TASK_POLL_INTERVAL_MS=5000
HERMES_REPAIR_PATH=/api/prompt
HERMES_REPAIR_MAX_TOKENS=3500
HERMES_BRIDGE_TOKEN=
# Keep false to avoid accidental OpenAI fallback spend when the local route fails.
HERMES_AGENT_FALLBACK=false

# Local storage
# Empty STORAGE_PROVIDER uses in-memory/data-url dev assets.
STORAGE_PROVIDER=

# Production / real commerce
ALLOW_MOCKS=false
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

PRINTFUL_API_KEY=
PRINTFUL_API_BASE=https://api.printful.com
PRINTFUL_STORE_ID=
PRINTFUL_CONFIRM_ORDERS=false
PRINTFUL_DEFAULT_SHIPPING=STANDARD
PRINTFUL_CURRENCY=USD
PRINTFUL_WEBHOOK_SECRET=

# R2 production asset storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=

# Drop economics
DROPLINK_SUMMON_PRICE_USDC=8
DROPLINK_TREASURY_ADDRESS=
DROPLINK_CREATOR_BOUNTY_BPS=800
DROPLINK_PROTOCOL_FEE_BPS=0
DROPLINK_TOTAL_SUPPLY=24
DROPLINK_RELICS_PER_DROP=3
DROPLINK_EDITIONS_PER_RELIC=8
DROPLINK_REQUIRE_PAYOUT_BEFORE_PUBLISH=false
DROPLINK_MIN_UNIT_MARGIN_USD=12
DROPLINK_PRICE_SAFETY_BUFFER_BPS=1000
DROPLINK_DEFAULT_REFUND_RESERVE_BPS=300
DROPLINK_MIN_UNIT_PRICE_USD=32
DROPLINK_MAX_UNIT_PRICE_USD=188

# x402 / Tempo
X402_ENABLED=false
X402_NETWORK=tempo
X402_ACCEPTED_ASSET=USDC
X402_RECIPIENT_ADDRESS=
X402_FACILITATOR_URL=
TEMPO_ENABLED=false
TEMPO_RPC_URL=
TEMPO_CHAIN_ID=
TEMPO_USDC_ADDRESS=
TEMPO_SETTLEMENT_CONTRACT_ADDRESS=
TEMPO_SETTLEMENT_PRIVATE_KEY=
TEMPO_SETTLEMENT_ABI_JSON=
TEMPO_SETTLEMENT_FUNCTION=
