# App
DROPLINK_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# Admin generation gate
DROPLINK_API_KEY=dev_local_key
DROPLINK_REQUIRE_GENERATION_KEY=true

# Database
# Required in production. Local JSON is only an explicit development fallback.
DATABASE_URL=
DROPLINK_DATA_FILE=
REDIS_URL=

# AI
AI_PROVIDER=mock
IMAGE_PROVIDER=mock
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_API_KEY=

# Stripe payment / subscriptions / Connect
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
DROPLINK_PREMIUM_PRICE_CENTS=8800
DROPLINK_PREMIUM_PRICE_USD=88

# Fulfillment
PRINTFUL_API_KEY=
PRINTFUL_API_BASE=https://api.printful.com
PRINTFUL_STORE_ID=
PRINTFUL_CONFIRM_ORDERS=false
PRINTFUL_DEFAULT_SHIPPING=STANDARD
PRINTFUL_CURRENCY=USD
PRINTFUL_WEBHOOK_SECRET=

# Mocks and storage
# In production, set ALLOW_MOCKS=true only for an explicit preview-only deployment.
ALLOW_MOCKS=false
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
