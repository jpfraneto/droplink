# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
DROPLINK_API_KEY=dev_local_key
DROPLINK_REQUIRE_GENERATION_KEY=false

# Database
# MVP uses local JSON storage by default. Set this for Railway Postgres when adding a Postgres adapter.
DATABASE_URL=

# AI
AI_PROVIDER=mock
OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Images
IMAGE_PROVIDER=mock
OPENAI_IMAGE_MODEL=gpt-image-2
IMAGE_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
DROPLINK_PLATFORM_FEE_BPS=800

# Optional Stripe Connect
STRIPE_CONNECT_CLIENT_ID=

# Fulfillment / print-on-demand providers for real products
FULFILLMENT_PROVIDER=manual
PRINTFUL_API_KEY=
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=
GELATO_API_KEY=

# Optional social/manual workflow
X_BEARER_TOKEN=
